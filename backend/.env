# Slack Bot Token — You need to create a Slack App and get this token
# Go to: https://api.slack.com/apps → Create New App → OAuth & Permissions
# Required scopes: chat:write, commands
SLACK_BOT_TOKEN=xoxb-REPLACE-WITH-YOUR-TOKEN

# Slack Signing Secret (from Slack App → Basic Information)
SLACK_SIGNING_SECRET=REPLACE-WITH-YOUR-SECRET

# Channel
SLACK_CHANNEL_ID=C08QR7PS3J8

# Port
PORT=8091

# Data file path
DATA_FILE=../data.json
