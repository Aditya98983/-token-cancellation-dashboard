# Slack Bot Token (xoxb-...) — Get from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-token-here

# Slack Signing Secret — For verifying slash command requests
SLACK_SIGNING_SECRET=your-signing-secret-here

# Channel ID for token cancellation requests
SLACK_CHANNEL_ID=C08QR7PS3J8

# Port for the backend server
PORT=8091

# Path to data.json (relative to backend folder)
DATA_FILE=../data.json
